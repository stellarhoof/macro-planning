{
  "extends": [
    "eslint:recommended",
    "plugin:import/recommended",
    "plugin:react/recommended",
    "plugin:react/jsx-runtime"
  ],
  "parserOptions": {
    "sourceType": "module",
    "ecmaVersion": 2022
  },
  "env": {
    "browser": true,
    "es2022": true
  },
  "rules": {
    "import/extensions": [2, { "js": "always" }],
    "react/display-name": "off",
    "react/prop-types": "off",
    "no-unused-vars": ["error", { "ignoreRestSiblings": true }]
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}
