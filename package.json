{
  "scripts": {
    "start": "snowpack dev",
    "predeploy": "snowpack build",
    "deploy": "gh-pages -d build"
  },
  "dependencies": {
    "@chakra-ui/react": "^1.6.3",
    "@emotion/react": "^11.4.0",
    "@emotion/styled": "^11.3.0",
    "framer-motion": "^4.1.17",
    "mobx": "^6.3.2",
    "mobx-react-lite": "^3.2.0",
    "mobx-state-tree": "^5.0.2",
    "mst-middlewares": "^5.0.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-icons": "^4.2.0",
    "react-table": "^7.7.0"
  },
  "devDependencies": {
    "eslint": "^7.28.0",
    "gh-pages": "^3.2.2",
    "prettier": "^2.3.1",
    "snowpack": "^3.5.6"
  },
  "snowpack": {
    "mount": {
      "public": "/",
      "src": "/dist"
    },
    "buildOptions": {
      "baseUrl": "/macro-planning",
      "metaUrlPath": "dist"
    }
  },
  "eslintConfig": {
    "parserOptions": {
      "sourceType": "module",
      "ecmaVersion": 2020,
      "ecmaFeatures": {
        "jsx": true
      }
    }
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "trailingComma": "es5",
    "arrowParens": "avoid"
  }
}
